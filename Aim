local function SameTeam(player)
    local result = false
    pcall(function()
        if LocalPlayer.Team ~= nil then
            result = (player.Team == LocalPlayer.Team)
            return
        end
        local lChar = LocalPlayer.Character
        local pChar = player.Character
        if lChar and pChar then
            local lTeam = lChar:GetAttribute("Team") or lChar:GetAttribute("TeamColor")
            local pTeam = pChar:GetAttribute("Team") or pChar:GetAttribute("TeamColor")
            if lTeam and pTeam then result = (lTeam == pTeam) end
        end
    end)
    return result
end

local _ignoreCache    = {}
local _ignoreCacheTick = 0
local function GetIgnoreList()
    if tick() - _ignoreCacheTick > 0.5 then
        _ignoreCache = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character then table.insert(_ignoreCache, p.Character) end
        end
        _ignoreCacheTick = tick()
    end
    return _ignoreCache
end

local function IsVisible(hrp)
    local ignoreList = GetIgnoreList()
    local origin = Camera.CFrame.Position
    local dir    = hrp.Position - origin
    local ray    = Ray.new(origin, dir.Unit * dir.Magnitude)
    local hit    = workspace:FindPartOnRayWithIgnoreList(ray, ignoreList)
    return hit == nil
end

local function HideAll(esp)
    for k, obj in pairs(esp) do
        if k == "_hl" then continue end
        pcall(function()
            if obj and obj.Visible ~= nil then obj.Visible = false end
        end)
    end
end

local function CleanupESP(player)
    local t = ESPObjects[player]
    if not t then return end
    for k, obj in pairs(t) do
        if k == "_hl" then
            pcall(function() obj:Destroy() end)
        elseif obj and type(obj) ~= "boolean" then
            pcall(function() obj:Remove() end)
        end
    end
    ESPObjects[player] = nil
end

local function BuildESP(player)
    if player == LocalPlayer then return end
    if ESPObjects[player] then CleanupESP(player) end
    local hl = nil
    pcall(function()
        hl = Instance.new("Highlight")
        hl.FillColor           = ChamsCfg.Color
        hl.OutlineColor        = ChamsCfg.Color
        hl.FillTransparency    = 0.5
        hl.OutlineTransparency = 0
        hl.Enabled             = false
        hl.Parent              = workspace
    end)
    ESPObjects[player] = {
