--   KILL ALL
-- ======================================================
local kaCooldown = {}
local KA_CD      = 5
local kaLastRun  = 0

local function KA_SetupPlayer(player)
    player.CharacterAdded:Connect(function()    kaCooldown[player] = tick() end)
    player.CharacterRemoving:Connect(function() kaCooldown[player] = tick() end)
end
for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then KA_SetupPlayer(p) end
end
Players.PlayerAdded:Connect(function(p)    if p ~= LocalPlayer then KA_SetupPlayer(p) end end)
Players.PlayerRemoving:Connect(function(p) kaCooldown[p] = nil end)

local function DoKillAll()
    if not AimbotCfg.KillAllEnabled then return end
    local now = tick()
    if now - kaLastRun < 0.05 then return end
    kaLastRun = now
    local localChar = LocalPlayer.Character
    local localHRP  = localChar and localChar:FindFirstChild("HumanoidRootPart")
    if not localHRP then return end
    local targets = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if AimbotCfg.TeamCheck and SameTeam(player) then continue end
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if not char or not hrp or not hum then continue end
        if hum.Health <= 0 then continue end
        local cd = kaCooldown[player] or 0
        if now - cd < KA_CD then continue end
        table.insert(targets, {player=player, hrp=hrp})
    end
    local count = #targets
    if count == 0 then return end
    for i, t in ipairs(targets) do
        pcall(function()
            local angle  = math.rad((360 / count) * (i - 1))
            local radius = count == 1 and 0 or 1.8
            local ox, oz = math.cos(angle)*radius, math.sin(angle)*radius
            local targetCF = localHRP.CFrame * CFrame.new(ox, 0, -2 + oz)
            t.hrp.CFrame = targetCF
            t.hrp.AssemblyLinearVelocity  = Vector3.zero
            t.hrp.AssemblyAngularVelocity = Vector3.zero
        end)
    end
end

-- ======================================================
--   FAKE LAG
-- ======================================================
local flFrozen = {}
local flTimer  = {}
local function DoFakeLag()
    if not FunCfg.FakeLag then flFrozen = {}; flTimer = {}; return end
    local now = tick()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not char or not hrp then flFrozen[player]=nil; flTimer[player]=nil; continue end
        if not flFrozen[player] then
            flFrozen[player] = hrp.CFrame
            flTimer[player]  = now
        else
            local elapsed = now - (flTimer[player] or now)
            if elapsed >= FunCfg.FakeLagDelay then
                flFrozen[player] = nil; flTimer[player] = nil
            else
                pcall(function()
                    hrp.CFrame = flFrozen[player]
                    hrp.AssemblyLinearVelocity  = Vector3.zero
                    hrp.AssemblyAngularVelocity = Vector3.zero
                end)
            end
        end
    end
end

