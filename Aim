-- ======================================================
--   UPDATE ESP
-- ======================================================
local espLastUpdate = 0
local ESP_RATE      = 1/30

local function UpdateESP()
    local now = tick()
    if now - espLastUpdate < ESP_RATE then return end
    espLastUpdate = now

    local vp = Camera.ViewportSize

    -- FOV Circle
    if FOVCircle then
        pcall(function()
            FOVCircle.Position = Vector2.new(vp.X/2, vp.Y/2)
            FOVCircle.Radius   = AimbotCfg.FOVRadius
            FOVCircle.Color    = AimbotCfg.FOVColor
            FOVCircle.Visible  = AimbotCfg.Enabled and AimbotCfg.ShowFOV
        end)
    end

    local enemyCount = 0

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local esp = ESPObjects[player]
        if not esp then continue end

        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")

        local anyESP = BoxCfg.Enabled or LineCfg.Enabled or HealthCfg.Enabled
                    or NameCfg.Enabled or DistanceCfg.Enabled or BoxTeamCfg.Enabled
                    or LineTeamCfg.Enabled or CountCfg.Enabled

        if not hrp or not hum or hum.Health <= 0 or not anyESP then
            HideAll(esp); continue
        end

        local localChar = LocalPlayer.Character
        local localHRP  = localChar and localChar:FindFirstChild("HumanoidRootPart")
        local dist3D    = localHRP and math.floor((hrp.Position - localHRP.Position).Magnitude) or 0

        if dist3D > MaxDist then HideAll(esp); continue end

        local isTeam = SameTeam(player)
        if not isTeam then enemyCount = enemyCount + 1 end

        -- Hitung posisi layar
        local topW = hrp.Position + Vector3.new(0, 3.2, 0)
        local botW = hrp.Position - Vector3.new(0, 3.2, 0)
        local top2D, topOnScreen = Camera:WorldToViewportPoint(topW)
        local bot2D, botOnScreen = Camera:WorldToViewportPoint(botW)

        if not topOnScreen and not botOnScreen then HideAll(esp); continue end

        local sTop = Vector2.new(top2D.X, top2D.Y)
        local sBot = Vector2.new(bot2D.X, bot2D.Y)
        local bH   = math.abs(sBot.Y - sTop.Y)
        local bW2  = bH * 0.5
        local L    = sTop.X - bW2 / 2
        local R    = sTop.X + bW2 / 2
        local T    = sTop.Y
        local B    = sBot.Y

        -- ── ENEMY BOX ──
        if BoxCfg.Enabled and not isTeam then
            pcall(function()
                local c, th = BoxCfg.Color, BoxCfg.Thickness
                esp.BoxTop.From    = Vector2.new(L,T); esp.BoxTop.To    = Vector2.new(R,T)
                esp.BoxBottom.From = Vector2.new(L,B); esp.BoxBottom.To = Vector2.new(R,B)
                esp.BoxLeft.From   = Vector2.new(L,T); esp.BoxLeft.To   = Vector2.new(L,B)
                esp.BoxRight.From  = Vector2.new(R,T); esp.BoxRight.To  = Vector2.new(R,B)
                for _, s in ipairs({esp.BoxTop, esp.BoxBottom, esp.BoxLeft, esp.BoxRight}) do
                    s.Color = c; s.Thickness = th; s.Visible = true
                end
            end)
        else
            pcall(function()
                esp.BoxTop.Visible=false; esp.BoxBottom.Visible=false
                esp.BoxLeft.Visible=false; esp.BoxRight.Visible=false
            end)
        end

        -- ── TEAM BOX ──
        if BoxTeamCfg.Enabled and isTeam then
            pcall(function()
                local c, th = BoxTeamCfg.Color, BoxTeamCfg.Thickness
                esp.BoxTeamTop.From    = Vector2.new(L,T); esp.BoxTeamTop.To    = Vector2.new(R,T)
                esp.BoxTeamBottom.From = Vector2.new(L,B); esp.BoxTeamBottom.To = Vector2.new(R,B)
                esp.BoxTeamLeft.From   = Vector2.new(L,T); esp.BoxTeamLeft.To   = Vector2.new(L,B)
                esp.BoxTeamRight.From  = Vector2.new(R,T); esp.BoxTeamRight.To  = Vector2.new(R,B)
                for _, s in ipairs({esp.BoxTeamTop, esp.BoxTeamBottom, esp.BoxTeamLeft, esp.BoxTeamRight}) do
                    s.Color = c; s.Thickness = th; s.Visible = true
                end
            end)
        else
            pcall(function()
                esp.BoxTeamTop.Visible=false; esp.BoxTeamBottom.Visible=false
                esp.BoxTeamLeft.Visible=false; esp.BoxTeamRight.Visible=false
            end)
        end

        -- ── ENEMY TRACER LINE ──
        if LineCfg.Enabled and not isTeam then
            pcall(function()
                local fromY = LineCfg.Mode=="Top" and 0 or LineCfg.Mode=="Middle" and vp.Y/2 or vp.Y
                esp.TracerLine.From      = Vector2.new(vp.X/2, fromY)
                esp.TracerLine.To        = Vector2.new(sTop.X, T)
                esp.TracerLine.Color     = LineCfg.Color
                esp.TracerLine.Thickness = LineCfg.Thickness
                esp.TracerLine.Visible   = true
            end)
        else
            pcall(function() esp.TracerLine.Visible = false end)
        end

        -- ── TEAM TRACER LINE ──
        if LineTeamCfg.Enabled and isTeam then
            pcall(function()
                local fromY = LineTeamCfg.Mode=="Top" and 0 or LineTeamCfg.Mode=="Middle" and vp.Y/2 or vp.Y
                esp.TracerLineTeam.From      = Vector2.new(vp.X/2, fromY)
                esp.TracerLineTeam.To        = Vector2.new(sTop.X, T)
                esp.TracerLineTeam.Color     = LineTeamCfg.Color
                esp.TracerLineTeam.Thickness = LineTeamCfg.Thickness
                esp.TracerLineTeam.Visible   = true
            end)
        else
            pcall(function() esp.TracerLineTeam.Visible = false end)
        end

        -- ── HEALTH TEXT ──
        if HealthCfg.Enabled then
            pcall(function()
                esp.HealthText.Text     = "HP " .. math.floor(hum.Health)
                esp.HealthText.Color    = HealthCfg.Color
                esp.HealthText.Position = Vector2.new(R + 5, T)
                esp.HealthText.Visible  = true
            end)
        else
            pcall(function() esp.HealthText.Visible = false end)
        end

        -- ── NAME TAG ──
        if NameCfg.Enabled then
            pcall(function()
                esp.NameTag.Text     = player.Name
                esp.NameTag.Color    = NameCfg.Color
                esp.NameTag.Position = Vector2.new(sTop.X, T - 16)
                esp.NameTag.Visible  = true
            end)
        else
            pcall(function() esp.NameTag.Visible = false end)
        end

        -- ── DISTANCE TAG ──
        if DistanceCfg.Enabled then
            pcall(function()
                local nameOff = NameCfg.Enabled and 14 or 0
                esp.DistTag.Text     = dist3D .. "m"
                esp.DistTag.Color    = DistanceCfg.Color
                esp.DistTag.Position = Vector2.new(sTop.X, T - 16 - nameOff)
                esp.DistTag.Visible  = true
            end)
        else
            pcall(function() esp.DistTag.Visible = false end)
        end
    end

    -- ── ENEMY COUNT DI TENGAH ATAS LAYAR ──
    if GlobalCountTag then
        if CountCfg.Enabled then
            pcall(function()
                GlobalCountTag.Text     = "ENEMY : " .. enemyCount
                GlobalCountTag.Color    = CountCfg.Color
                GlobalCountTag.Position = Vector2.new(vp.X / 2, 10)
                GlobalCountTag.Visible  = true
            end)
        else
            pcall(function() GlobalCountTag.Visible = false end)
        end
    end
end

